rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: rooms
    // Document ID: 6-digit room code
    // Fields:
    //   - code: string (required, 6 chars)
    //   - users: list of User objects (required, max 100)
    //   - queue: list of MediaItem objects (required, max 500)
    //   - currentMedia: map (required)
    //   - messages: list of objects (required, max 1000)
    //   - logs: list of strings (required, max 1000)
    //   - history: list of MediaItem objects (optional, max 100)
    //   - shuffle: bool (optional)
    //   - repeatMode: string (optional, enum: ['none', 'one', 'all'])
    //
    // Collection: users
    // Document ID: Firebase Auth UID
    // Fields:
    //   - favorites: list of QueueItem objects (required, max 500)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidRoom(data) {
      return data.code is string && data.code.size() == 6 &&
             data.users is list && data.users.size() <= 100 &&
             data.queue is list && data.queue.size() <= 500 &&
             data.messages is list && data.messages.size() <= 1000 &&
             data.logs is list && data.logs.size() <= 1000 &&
             data.currentMedia is map &&
             (!('history' in data) || (data.history is list && data.history.size() <= 100)) &&
             (!('repeatMode' in data) || data.repeatMode in ['none', 'one', 'all']);
    }

    function isValidUser(data) {
      return data.favorites is list && data.favorites.size() <= 500;
    }

    match /rooms/{roomId} {
      // Allow any authenticated user to read/write rooms for now to ensure sync works.
      // In a more restricted setup, we'd check if the user is in the 'users' list.
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidRoom(request.resource.data);
      allow update: if isAuthenticated() && isValidRoom(request.resource.data);
      allow delete: if false;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
      allow delete: if false;
    }
  }
}
